# Copia este archivo a .env.local y rellena los valores.

# Supabase (obligatorio para login y datos)
# La sesión se guarda en cookies (middleware + panel); en HTTPS en producción.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional pero recomendado: perfil/avatar y citas (adjuntos Storage) vía service role
# SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets sync de citas (opcional; sin esto la cita igual se guarda en Supabase)
# Ver docs/CITAS_SETUP.md
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Gemini — Asistente IA en Orden de recolección (solo servidor)
# Clave en https://aistudio.google.com/apikey (no la subas a git; usa .env.local)
GEMINI_API_KEY=
# Opcional; por defecto se usa gemini-flash-latest
# GEMINI_MODEL=gemini-flash-latest
#
# Velocidad — PDF con texto: el servidor suele usar solo texto (sin multimodal).
# Para forzar SIEMPRE análisis del PDF como archivo (más lento): GEMINI_FORCE_PDF_VISION=1
# Si envías PDF/imagen al modelo sin ruta rápida: GEMINI_MEDIA_RESOLUTION=low|medium|high (por defecto low)
# GEMINI_FORCE_PDF_VISION=
# GEMINI_MEDIA_RESOLUTION=
# Opcional: no hacer segundo intento si falla el parseo JSON (por defecto sí se reintenta)
# GEMINI_SKIP_JSON_RETRY=1
# Opcional: tras fallar el JSON con esquema, no usar los fallbacks JSON libre + texto (por defecto sí)
# GEMINI_SKIP_LOOSE_JSON_FALLBACK=1
# Opcional: si el JSON falla, no usar el último recurso de extracción por tabla markdown (tipo Gemini web)
# GEMINI_SKIP_MARKDOWN_TABLE_FALLBACK=1
#
# PDF / texto largo — fragmentación en el servidor (más filas completas, menos JSON roto)
# Por defecto Alde.IA elige automáticamente el perfil según tamaño y filas estimadas:
#   normal → 30 fragmentos | largo → 40 | extremo → 50
# Si defines GEMINI_PDF_MAX_CHUNKS, desactiva la auto-detección y usa ese tope fijo.
# Tamaño aproximado de cada fragmento (caracteres), solapamiento, umbral para partir (tope interno 50)
# GEMINI_PDF_TEXT_CHUNK_CHARS=38000
# GEMINI_PDF_TEXT_CHUNK_OVERLAP=2400
# GEMINI_PDF_TEXT_CHUNK_MIN=14000
# GEMINI_PDF_MAX_CHUNKS=30
#
# Memoria Alde.IA: tabla `gemini_learning_notes` (migración 008). Sin ella, el panel muestra error al guardar reglas.

# Opcional: límites orientativos para el texto "cuántas consultas faltan" en el panel
# (Google no devuelve el cupo exacto; ajusta según lo que veas en AI Studio para tu plan)
# NEXT_PUBLIC_GEMINI_QUOTA_RPD=1500
# NEXT_PUBLIC_GEMINI_QUOTA_RPM=15

# OpenAI — AldeGpt Terra (chat general en Orden de recolección; solo servidor)
# Clave en https://platform.openai.com/api-keys (nunca uses NEXT_PUBLIC_ ni la subas a git)
OPENAI_API_KEY=COLOCAR_CLAVE_AQUI
